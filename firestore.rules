rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function hasProfile() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function myProfile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function activeProfile() { return hasProfile() && (!('accountStatus' in myProfile().data) || myProfile().data.accountStatus == 'active'); }
    function myRole() { return hasProfile() ? myProfile().data.role : null; }
    function staff() { return activeProfile() && myRole() in ['reviewer', 'seniorReviewer', 'hiringLead', 'executive', 'owner']; }
    function finalDecision() { return activeProfile() && myRole() in ['executive', 'owner']; }
    function owner() { return activeProfile() && myRole() == 'owner'; }
    function firstOwnerNotCreated() { return !exists(/databases/$(database)/documents/system/ownerBootstrap); }
    function ownApplicationId(applicationId) { return applicationId.matches('^' + request.auth.uid + '_.*$'); }
    function changedOnly(keys) { return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys); }
    function noRecommendationYet() { return !('reviewerRecommendation' in resource.data) || resource.data.reviewerRecommendation == ''; }

    function autoUnderReview() {
      return staff()
        && resource.data.status == 'submitted'
        && request.resource.data.status == 'underReview'
        && changedOnly(['status', 'reviewedBy', 'reviewedByUsername', 'updatedAt']);
    }

    function reviewerRecommendationWorkflow() {
      return staff()
        && !owner()
        && noRecommendationYet()
        && request.resource.data.status == 'pendingFinalDecision'
        && request.resource.data.reviewerRecommendation is string
        && request.resource.data.reviewerRecommendation != ''
        && changedOnly(['status', 'reviewerRecommendation', 'reviewedBy', 'reviewedByUsername', 'updatedAt']);
    }

    function executiveRecommendationWorkflow() {
      return finalDecision()
        && !owner()
        && request.resource.data.status == 'pendingFinalDecision'
        && changedOnly(['status', 'reviewerRecommendation', 'publicMessage', 'reviewedBy', 'reviewedByUsername', 'updatedAt']);
    }

    match /system/{docId} {
      allow read: if owner();
      allow create: if signedIn() && docId == 'ownerBootstrap' && firstOwnerNotCreated() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /discord_ids/{discordId} {
      allow read: if false;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if owner();
    }

    match /users/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid || staff());
      allow create: if signedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.accountStatus == 'active'
        && (request.resource.data.role == 'applicant' || (request.resource.data.role == 'owner' && firstOwnerNotCreated()));
      allow update: if signedIn() && ((uid == request.auth.uid && activeProfile() && request.resource.data.role == resource.data.role && request.resource.data.uid == resource.data.uid && request.resource.data.accountStatus == resource.data.accountStatus) || owner());
      allow delete: if owner();
    }

    match /application_forms/{formId} {
      allow read: if true;
      allow create, update: if finalDecision();
      allow delete: if owner();
    }

    match /applications/{applicationId} {
      allow get: if signedIn() && activeProfile() && (ownApplicationId(applicationId) || staff());
      allow list: if signedIn() && activeProfile() && (resource.data.applicantUid == request.auth.uid || staff());
      allow create: if signedIn()
        && activeProfile()
        && applicationId == request.auth.uid + '_' + request.resource.data.formId
        && request.resource.data.applicantUid == request.auth.uid
        && request.resource.data.status in ['draft', 'submitted']
        && !('decision' in request.resource.data)
        && !('reviewerNotes' in request.resource.data);
      allow update: if signedIn() && activeProfile() && (
        (resource.data.applicantUid == request.auth.uid
          && applicationId == request.auth.uid + '_' + resource.data.formId
          && resource.data.status == 'draft'
          && request.resource.data.applicantUid == request.auth.uid
          && request.resource.data.formId == resource.data.formId
          && request.resource.data.status in ['draft', 'submitted']
          && !('decision' in request.resource.data)
          && !('reviewerNotes' in request.resource.data))
        || owner()
        || autoUnderReview()
        || reviewerRecommendationWorkflow()
        || executiveRecommendationWorkflow()
      );
      allow delete: if owner();
    }

    match /review_notes/{noteId} {
      allow read, create, update: if staff();
      allow delete: if finalDecision();
    }

    match /account_notes/{noteId} {
      allow read, create, update, delete: if owner();
    }

    match /audit_logs/{logId} {
      allow read: if staff();
      allow create: if activeProfile();
      allow update, delete: if false;
    }
  }
}
