rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Free-plan static-hosting version.
    // This portal does not use Firebase Auth or Functions, so rules must allow the static app to read/write.
    // Do not use this for sensitive real-world hiring records.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
